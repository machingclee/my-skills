<!--
  Merge into the project's <dependencies>. S3Presigner ships in the s3 artifact.
  If the project already imports the AWS SDK BOM (software.amazon.awssdk:bom),
  omit the <version>; otherwise pin it (2.29.0 matches the echarge reference).
-->
<dependency>
    <groupId>software.amazon.awssdk</groupId>
    <artifactId>s3</artifactId>
    <version>2.29.0</version>
</dependency>

