# AWS Cognito Configuration
VITE_COGNITO_USER_POOL_ID=<your-user-pool-id>
VITE_COGNITO_CLIENT_ID=<your-client-id>
VITE_AWS_REGION=us-east-1

# AgentCore Runtime Endpoint (from agentcore deploy output or AWS Console)
VITE_AGENT_ENDPOINT=<your-agentcore-invocation-url>

# Bot Login Credentials (Cognito user with access to the runtime)
VITE_BOT_USERNAME=<bot-username>
VITE_BOT_PASSWORD=<bot-password>

# Chat mode: "custom" (default, hand-built ChatInterface) or "copilotkit" (CopilotKit-powered)
VITE_CHAT_MODE=custom
